<Window x:Class="BryanYOLO.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BryanYOLO"
        xmlns:controls="clr-namespace:BryanYOLO.Controls"
        xmlns:vm="clr-namespace:BryanYOLO.ViewModels"
        xmlns:converters="clr-namespace:BryanYOLO.Converters"
        mc:Ignorable="d"
        Title="BryanYOLO - AI图片标注工具" 
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- 添加选中项样式 -->
        <Style x:Key="ImageListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" 
                                BorderBrush="LightGray" 
                                BorderThickness="1" 
                                Margin="2" 
                                Padding="5" 
                                CornerRadius="3"
                                Background="White">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="Blue"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="Border" Property="Background" Value="#FFE8F4FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFF0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="Left" Command="{Binding PreviousImageCommand}"/>
        <KeyBinding Key="Right" Command="{Binding NextImageCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveAnnotationsCommand}"/>
        <KeyBinding Key="F1" Command="{Binding ShowHelpCommand}"/>
        <KeyBinding Key="Delete" Modifiers="Shift" Command="{Binding DeleteCurrentImageCommand}"/>
        <KeyBinding Key="OemPlus" Modifiers="Ctrl" Command="{x:Null}"/>
        <KeyBinding Key="OemMinus" Modifiers="Ctrl" Command="{x:Null}"/>
        <KeyBinding Key="D0" Modifiers="Ctrl" Command="{x:Null}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 菜单栏 -->
        <Menu Grid.Row="0">
            <MenuItem Header="文件">
                <MenuItem Header="打开文件夹" Command="{Binding LoadFolderCommand}"/>
                <MenuItem Header="打开YAML项目" Command="{Binding LoadYamlCommand}"/>
                <Separator/>
                <MenuItem Header="另存为项目..." Command="{Binding SaveProjectAsCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="💾" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="导出YOLO格式" Command="{Binding ExportYoloCommand}"/>
                <Separator/>
                <MenuItem Header="退出" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="编辑">
                <MenuItem Header="保存标注" Command="{Binding SaveAnnotationsCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="清空标注" Command="{Binding ClearAnnotationsCommand}"/>
                <Separator/>
                <MenuItem Header="删除当前图片" Command="{Binding DeleteCurrentImageCommand}" InputGestureText="Shift+Delete"/>
                <Separator/>
                <MenuItem Header="管理类别" Command="{Binding ManageClassesCommand}"/>
            </MenuItem>
            <MenuItem Header="工具">
                <MenuItem Header="AI推理" Click="OnOpenInferenceDialog">
                    <MenuItem.Icon>
                        <TextBlock Text="🤖" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="标签识别修正" Click="OnOpenLabelAdjustmentDialog">
                    <MenuItem.Icon>
                        <TextBlock Text="🎯" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="推测标注" Click="OnOpenInferAnnotationDialog">
                    <MenuItem.Icon>
                        <TextBlock Text="🔮" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="使用说明" Command="{Binding ShowHelpCommand}" InputGestureText="F1"/>
                <MenuItem Header="关于 BryanYOLO" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- 工具栏 -->
        <ToolBar Grid.Row="1">
            <Button Command="{Binding LoadFolderCommand}" ToolTip="打开文件夹">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📁" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="打开文件夹"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding LoadYamlCommand}" ToolTip="打开YAML项目">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📄" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="打开项目"/>
                </StackPanel>
            </Button>

            <Separator/>

            <Button Command="{Binding SaveAnnotationsCommand}" ToolTip="保存标注">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💾" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="保存"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding SaveProjectAsCommand}" ToolTip="另存为项目（保存部分图片）">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📦" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="另存为项目"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding ClearAnnotationsCommand}" ToolTip="清空标注并创建空标记">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🗑️" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="清空标注"/>
                </StackPanel>
            </Button>

            <Separator/>

            <TextBlock Text="筛选:" VerticalAlignment="Center"/>
            <ComboBox Width="120" x:Name="FilterComboBox">
                <ComboBoxItem Content="全部" Tag="{x:Null}" IsSelected="True"/>
                <ComboBoxItem Content="已标记" Tag="Annotated"/>
                <ComboBoxItem Content="空标记" Tag="EmptyAnnotation"/>
                <ComboBoxItem Content="未标记" Tag="NotAnnotated"/>
            </ComboBox>

            <Separator/>

            <TextBlock Text="当前类别:" VerticalAlignment="Center"/>
            <ComboBox Width="100" 
                  ItemsSource="{Binding CurrentProject.Classes}" 
                  SelectedIndex="{Binding SelectedClassId, Mode=TwoWay}" 
                  x:Name="ClassSelector"/>


            <Button Command="{Binding ManageClassesCommand}" ToolTip="管理类别">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📝" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="管理类别"/>
                </StackPanel>
            </Button>

            <Separator/>

            <!-- AI推理部分 -->
            <Button Click="OnOpenInferenceDialog" ToolTip="AI推理">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🤖" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="AI推理"/>
                </StackPanel>
            </Button>

            <!-- 标签识别修正按钮 -->
            <Button Click="OnOpenLabelAdjustmentDialog" 
                    ToolTip="通过图标识别调整标注框">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🎯" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="标签识别修正"/>
                </StackPanel>
            </Button>

            <!-- 推测标注按钮 -->
            <Button Click="OnOpenInferAnnotationDialog"
                    ToolTip="基于现有框体推测其他框体位置">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔮" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="推测标注"/>
                </StackPanel>
            </Button>

            <Separator/>

            <!-- 删除图片按钮 -->
            <Button Command="{Binding DeleteCurrentImageCommand}" 
                    ToolTip="删除当前图片 (Shift+Delete)"
                    Background="#FFFFEEEE">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="❌" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="删除图片"/>
                </StackPanel>
            </Button>
        </ToolBar>

        <!-- 主内容区 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="300" MinWidth="250"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧图片列表 -->
            <GroupBox Grid.Column="0" Header="图片列表">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 图片统计信息 -->
                    <Border Grid.Row="0" Background="LightGray" Padding="5" Margin="0,0,0,5">
                        <TextBlock FontSize="11" TextAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="共 {0} 张图片">
                                    <Binding Path="FilteredImages.Count"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>

                    <!-- 图片列表 -->
                    <ListBox Grid.Row="1" 
                             x:Name="ImageListBox"
                             ItemsSource="{Binding FilteredImages}" 
                             SelectedItem="{Binding CurrentImage}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource ImageListBoxItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="删除此图片" 
                                                      Command="{Binding DataContext.DeleteCurrentImageCommand, 
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="❌" Foreground="Red"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                    <StackPanel>
                                        <TextBlock Text="{Binding FileName}" FontWeight="Bold"/>
                                        <TextBlock FontSize="10">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Annotated">
                                                            <Setter Property="Text" Value="✅ 已标记"/>
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="EmptyAnnotation">
                                                            <Setter Property="Text" Value="⭕ 空标记"/>
                                                            <Setter Property="Foreground" Value="Orange"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="NotAnnotated">
                                                            <Setter Property="Text" Value="❌ 未标记"/>
                                                            <Setter Property="Foreground" Value="Red"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 跳转控制面板 -->
                    <Border Grid.Row="2" Background="#F0F0F0" Padding="5" Margin="0,5,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 当前位置显示 -->
                            <TextBlock Grid.Row="0" 
                                       FontSize="12" 
                                       TextAlignment="Center"
                                       FontWeight="Bold"
                                       Margin="0,0,0,5">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="当前: {0} / {1}">
                                        <Binding Path="CurrentImageIndex"/>
                                        <Binding Path="FilteredImages.Count"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- 跳转输入 -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="跳转:" 
                                           VerticalAlignment="Center"
                                           Margin="0,0,5,0"/>

                                <TextBox Grid.Column="1" 
                                         x:Name="JumpToIndexTextBox"
                                         VerticalAlignment="Center"
                                         HorizontalContentAlignment="Center"
                                         PreviewTextInput="OnJumpNumberPreviewTextInput"
                                         KeyDown="OnJumpToIndexKeyDown"/>

                                <Button Grid.Column="2" 
                                        Content="GO"
                                        Padding="8,2"
                                        Margin="5,0,0,0"
                                        Click="OnJumpToImage"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>

            <!-- 第一个分隔条 -->
            <GridSplitter Grid.Column="1" 
                          Width="3" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch" 
                          Background="Gray"/>

            <!-- 中间图片显示区 -->
            <GroupBox Grid.Column="2" Header="图片标注">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 缩放控制栏 -->
                    <ToolBar Grid.Row="0" Height="30">
                        <Button x:Name="ZoomInButton" Click="OnZoomIn" ToolTip="放大 (Ctrl+鼠标滚轮)">
                            <TextBlock Text="🔍+" FontSize="14"/>
                        </Button>
                        <Button x:Name="ZoomOutButton" Click="OnZoomOut" ToolTip="缩小 (Ctrl+鼠标滚轮)">
                            <TextBlock Text="🔍-" FontSize="14"/>
                        </Button>
                        <Separator/>
                        <TextBlock Text="缩放:" VerticalAlignment="Center" Margin="5,0"/>
                        <TextBlock x:Name="ZoomLevelText" Text="100%" Width="50" VerticalAlignment="Center" FontWeight="Bold"/>
                        <Separator/>
                        <Button x:Name="Zoom100Button" Click="OnZoom100" ToolTip="原始大小">
                            <TextBlock Text="100%"/>
                        </Button>
                        <Button x:Name="ZoomFitButton" Click="OnZoomFit" ToolTip="适应窗口">
                            <TextBlock Text="适应"/>
                        </Button>
                        <Separator/>
                        <TextBlock Text="导航: WASD移动 | 右键拖动 | Ctrl+滚轮缩放" 
                                   VerticalAlignment="Center" 
                                   Foreground="Gray" 
                                   FontSize="11"
                                   Margin="10,0"/>
                    </ToolBar>

                    <!-- 图片显示区域 -->
                    <Grid Grid.Row="1" Background="DarkGray">
                        <ScrollViewer x:Name="ImageScrollViewer"
                                      HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="OnPreviewMouseWheel"
                                      PreviewMouseRightButtonDown="OnScrollViewerMouseRightButtonDown"
                                      PreviewMouseMove="OnScrollViewerMouseMove"
                                      PreviewMouseRightButtonUp="OnScrollViewerMouseRightButtonUp">
                            <Grid x:Name="ImageContainer"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <Grid.LayoutTransform>
                                    <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                                </Grid.LayoutTransform>

                                <Image Source="{Binding CurrentBitmap}" 
                                       x:Name="MainImage"
                                       Stretch="None"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                                <controls:ImageCanvas 
                                x:Name="AnnotationCanvas"
                                Annotations="{Binding CurrentImage.Annotations}"
                                ClassColors="{Binding ClassColors}"
                                SelectedClassId="{Binding SelectedClassId, Mode=TwoWay}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="True"/>
                            </Grid>
                        </ScrollViewer>

                        <!-- 加载指示器 -->
                        <Border Background="#80000000" 
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                                <TextBlock Text="处理中..." Foreground="White" 
                                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </GroupBox>

            <!-- 第二个分隔条 -->
            <GridSplitter Grid.Column="3" 
                          Width="3" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch" 
                          Background="Gray"/>

            <!-- 右侧标注信息 -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>

                <!-- 当前标注属性 -->
                <GroupBox Grid.Row="0" Header="当前标注属性" Margin="0,0,0,5">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" Margin="0,0,5,0"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="XValueText" Text="-" Margin="0,0,10,0"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Y:" Margin="0,0,5,0"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" x:Name="YValueText" Text="-"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="W:" Margin="0,5,5,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="WValueText" Text="-" Margin="0,5,10,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="H:" Margin="0,5,5,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="3" x:Name="HValueText" Text="-" Margin="0,5,0,0"/>
                    </Grid>
                </GroupBox>

                <!-- 标注列表 -->
                <GroupBox Grid.Row="1" Header="标注列表">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 标注统计 -->
                        <Border Grid.Row="0" Background="LightYellow" Padding="3" Margin="0,0,0,3">
                            <TextBlock FontSize="11" TextAlignment="Center">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="共 {0} 个标注">
                                        <Binding Path="CurrentImage.Annotations.Count"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Border>

                        <!-- 标注列表 -->
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding CurrentImage.Annotations}"
                                 x:Name="AnnotationListBox"
                                 SelectionChanged="OnAnnotationSelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="LightGray" BorderThickness="1" 
                                            Margin="2" Padding="5" CornerRadius="3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding ClassId}" 
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding DisplayName}"
                                                       Margin="5,0"
                                                       VerticalAlignment="Center"/>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="选择" 
                                                        Tag="{Binding}"
                                                        Click="OnSelectAnnotation"
                                                        Padding="5,2" 
                                                        Margin="2"
                                                        ToolTip="选中此标注"/>
                                                <Button Content="类别" 
                                                        Tag="{Binding}"
                                                        Click="OnChangeAnnotationClass"
                                                        Padding="5,2" 
                                                        Margin="2"
                                                        ToolTip="更换类别"/>
                                                <Button Content="删除"
                                                        Tag="{Binding}"
                                                        Click="OnDeleteAnnotation"
                                                        Padding="5,2" 
                                                        Margin="2"
                                                        ToolTip="删除此标注"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </GroupBox>

                <!-- TXT预览 -->
                <GroupBox Grid.Row="3" Header="TXT标记预览">
                    <TextBox Text="{Binding AnnotationText}" 
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="11"/>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- 底部缩略图 -->
        <Grid Grid.Row="3">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding PreviousImageCommand}" 
                            VerticalAlignment="Center"
                            Content="⬅ 上一张 (←)" Margin="5"/>

                    <!-- 前面的缩略图 -->
                    <ItemsControl ItemsSource="{Binding PreviousThumbnails}" Margin="5,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Gray" BorderThickness="1" Margin="2">
                                    <Image Source="{Binding}" 
                                           Width="100" Height="80" 
                                           Stretch="Uniform"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 当前图片高亮 -->
                    <Border BorderBrush="Blue" BorderThickness="3" Margin="2">
                        <Image Source="{Binding CurrentBitmap}" 
                               Width="120" Height="100" 
                               Stretch="Uniform"/>
                    </Border>

                    <!-- 后面的缩略图 -->
                    <ItemsControl ItemsSource="{Binding NextThumbnails}" Margin="5,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Gray" BorderThickness="1" Margin="2">
                                    <Image Source="{Binding}" 
                                           Width="100" Height="80" 
                                           Stretch="Uniform"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Command="{Binding NextImageCommand}" 
                            VerticalAlignment="Center"
                            Content="下一张 (→) ➡" Margin="5"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Text>
                        <MultiBinding StringFormat="图片: {0} / {1}">
                            <Binding Path="CurrentImageIndex"/>
                            <Binding Path="FilteredImages.Count"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="版本: 1.5.0" Foreground="Gray"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>