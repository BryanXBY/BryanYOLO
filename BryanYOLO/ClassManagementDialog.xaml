<Window x:Class="BryanYOLO.Dialogs.ClassManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="类别管理" 
        Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="项目类别列表：" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- 类别列表 -->
        <DataGrid Grid.Row="1" 
                  x:Name="ClassesDataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="True"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" 
                                    Binding="{Binding Index}" 
                                    Width="50" 
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="类别名称" 
                                    Binding="{Binding Name}" 
                                    Width="*"/>
                <DataGridTemplateColumn Header="颜色" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Rectangle Width="40" Height="20" 
                                       Fill="{Binding ColorBrush}" 
                                       Stroke="Black" 
                                       StrokeThickness="1"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="操作" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="删除" 
                                    Click="OnDeleteClass"
                                    Tag="{Binding}"
                                    Padding="5,2"
                                    Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 添加新类别 -->
        <GroupBox Grid.Row="2" Header="添加新类别" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="NewClassTextBox" 
                         Grid.Column="0"
                         Margin="0,0,5,0"
                         KeyDown="OnNewClassKeyDown"/>
                <Button Grid.Column="1" 
                        Content="添加" 
                        Width="60"
                        Click="OnAddClass"/>
            </Grid>
        </GroupBox>

        <!-- 按钮 -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="确定" 
                    Width="80" 
                    Margin="0,0,5,0"
                    IsDefault="True"
                    Click="OnOK"/>
            <Button Content="取消" 
                    Width="80" 
                    IsCancel="True"
                    Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>