<Window x:Class="BryanYOLO.Dialogs.ModelPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ONNX模型检测预览" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="LightBlue" Padding="10">
            <TextBlock Text="ONNX模型检测预览 - 查看模型检测到的所有目标" 
                       FontSize="16" FontWeight="Bold"/>
        </Border>

        <!-- 主要内容区 -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：图片显示区 -->
            <GroupBox Grid.Column="0" Header="检测结果可视化">
                <Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Auto"
                                  x:Name="ImageScrollViewer">
                        <Grid>
                            <Image x:Name="PreviewImage" 
                                   Stretch="None"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                            <Canvas x:Name="DetectionCanvas"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </ScrollViewer>

                    <!-- 加载中提示 -->
                    <Border x:Name="LoadingPanel" 
                            Background="#80000000" 
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" 
                                    VerticalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" 
                                         Width="200" Height="20"/>
                            <TextBlock Text="正在运行模型检测..." 
                                       Foreground="White" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </GroupBox>

            <!-- 右侧：检测结果列表 -->
            <GroupBox Grid.Column="1" Header="检测结果详情" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 统计信息 -->
                    <Border Grid.Row="0" Background="LightYellow" 
                            Padding="5" Margin="0,0,0,5">
                        <StackPanel>
                            <TextBlock x:Name="TotalDetectionsText" 
                                       Text="总检测数: 0" 
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="FilteredDetectionsText" 
                                       Text="目标类别数: 0" 
                                       Foreground="Green"/>
                            <TextBlock x:Name="ThresholdText" 
                                       Text="置信度阈值: 0.5" 
                                       FontSize="11" 
                                       Foreground="Gray"/>
                        </StackPanel>
                    </Border>

                    <!-- 检测结果列表 -->
                    <ListBox Grid.Row="1" x:Name="DetectionListBox"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" 
                                        BorderThickness="1" 
                                        Margin="2" 
                                        Padding="5" 
                                        CornerRadius="3">
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="类别ID: {0}">
                                                    <Binding Path="ClassId"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock FontSize="11">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="置信度: {0:F3}">
                                                    <Binding Path="Confidence"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="Gray">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="位置: ({0}, {1})">
                                                    <Binding Path="Center.X"/>
                                                    <Binding Path="Center.Y"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="Gray">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="大小: {0}x{1}">
                                                    <Binding Path="Bounds.Width"/>
                                                    <Binding Path="Bounds.Height"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 类别过滤 -->
                    <StackPanel Grid.Row="2" Margin="0,5,0,0">
                        <TextBlock Text="筛选类别ID:" Margin="0,0,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="FilterClassIdTextBox" 
                                     Text="" 
                                     ToolTip="输入类别ID进行筛选，留空显示全部"/>
                            <Button Grid.Column="1" Content="筛选" 
                                    Width="60" 
                                    Margin="5,0,0,0"
                                    Click="OnFilterClick"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 信息面板 -->
        <Border Grid.Row="2" Background="LightGray" Padding="10" Margin="10,5">
            <TextBlock x:Name="InfoText" 
                       TextWrapping="Wrap"
                       Text="提示：不同颜色的框代表不同的类别ID。红色框表示您指定的目标类别。"/>
        </Border>

        <!-- 按钮面板 -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="10">
            <Button x:Name="RefreshButton" 
                    Content="重新检测" 
                    Width="100" 
                    Margin="0,0,5,0"
                    Click="OnRefreshClick"/>
            <Button Content="关闭" 
                    Width="100" 
                    IsCancel="True"
                    Click="OnCloseClick"/>
        </StackPanel>
    </Grid>
</Window>